# 이 파일을 ".env"로 복사한 뒤 실제 값을 입력하세요.

# OpenAI API 키. 비어 있으면 DUMMY(데모) 모드로 실행됩니다.
OPENAI_API_KEY=

# OpenAI 채팅 모델. gpt-4o-mini가 저렴하고 빠릅니다.
OPENAI_MODEL=gpt-4o-mini

# google script로 배포했던 스프레드시트 웹훅 URL
ZAPIER_WEBHOOK_URL=

# 개발자 모드 활성화 암호. 비어 있으면 암호 없이 토글 가능합니다.
DEV_TOGGLE_PASSWORD=1234

# 채용 담당자 페이지 접근 암호. 비어 있으면 암호 없이 접근 가능합니다.
RECRUITER_PASSWORD=1234