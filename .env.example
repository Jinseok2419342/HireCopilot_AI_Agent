# 이 파일을 ".env"로 복사한 뒤 실제 값을 입력하세요.

# OpenAI API 키. 비어 있으면 DUMMY(데모) 모드로 실행됩니다.
OPENAI_API_KEY=

# OpenAI 채팅 모델. gpt-4o-mini가 저렴하고 빠릅니다.
OPENAI_MODEL=gpt-4o-mini

# GAS 멀티 시트 웹훅 URL (gas/webhook_router.gs 배포 URL)
GAS_WEBHOOK_URL=
# 하위 호환용 (GAS_WEBHOOK_URL 미설정 시 사용)
ZAPIER_WEBHOOK_URL=

# 2차 파이프라인 — 관리자 알림 (outbox 시트 → 전용 Zap)
ADMIN_EMAIL=
ADMIN_SLACK_USER_ID=
NOTION_DATABASE_LABEL=2026 보류 합격자 목록

# 파이프라인 자격 필터 (pipeline.py)
PIPELINE_MIN_GPA=3.0
PIPELINE_REQUIRE_GPA=true
PIPELINE_BLOCK_NEWGRAD=false

# 개발자 모드 활성화 암호. 비어 있으면 암호 없이 토글 가능합니다.
DEV_TOGGLE_PASSWORD=1234

# 채용 담당자 페이지 접근 암호. 비어 있으면 암호 없이 접근 가능합니다.
RECRUITER_PASSWORD=1234
